spring.application.name=wilayah-api

# Server
server.port=8080

# MySQL
spring.datasource.url=jdbc:mysql://localhost:3306/wilayah?useSSL=false&serverTimezone=Asia/Jakarta&allowPublicKeyRetrieval=true
spring.datasource.username=wilayah
spring.datasource.password=your_password
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA / Hibernate
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# CORS - allowed origins
app.cors.allowed-origins=http://localhost:5173,http://localhost:5174,http://localhost:4200,http://localhost:3000
